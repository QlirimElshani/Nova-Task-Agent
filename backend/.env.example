# Copy to .env and fill in real values. .env is gitignored.
# Every variable the app reads (app/core/config.py) is listed here.

# Environment name: "development" | "production".
ENV=development

# Database connection (async SQLAlchemy URL).
# Default is a local SQLite file (zero setup). For Postgres use e.g.:
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nova
DATABASE_URL=sqlite+aiosqlite:///./nova.db

# Anthropic API key for the Nova endpoint (POST /api/v1/nova/parse).
# If left blank, the endpoint falls back to a local rule-based parser
# so the app still works without a key.
ANTHROPIC_API_KEY=

# Claude model used by the Nova endpoint.
NOVA_MODEL=claude-sonnet-4-6

# ── Auth / JWT ──
# Secret used to sign access tokens. CHANGE THIS for any real deployment.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-change-me
# Signing algorithm (HMAC). Leave as HS256 unless you know you need otherwise.
JWT_ALGORITHM=HS256
# Access-token lifetime in minutes (default 10080 = 7 days).
JWT_EXPIRE_MINUTES=10080

# Allowed CORS origins as a JSON array. Expo web dev server + devices.
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006","*"]

# Log verbosity: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
